// =============================================================================
// Family Finance — Prisma Schema (Milestone 2)
// =============================================================================
// Database: PostgreSQL (Supabase)
// ORM: Prisma 7.8.0
// Connection: Via adapter (@prisma/adapter-pg) — see src/lib/prisma.ts
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Note: Prisma 7 does not use `url` here — connection handled via adapter
}

// =============================================================================
// ENUMS
// =============================================================================

enum Role {
  ADMIN   // Full access to family
  PARENT  // Can manage transactions, budgets, bills, members
  CHILD   // View-only + can add personal transactions if allowed
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  YEARLY
}

enum BillStatus {
  UPCOMING  // Not yet due
  OVERDUE   // Past due date
  PAID      // Marked as paid
}

enum NotificationType {
  BUDGET_WARNING    // Budget 80% reached
  BUDGET_EXCEEDED   // Budget 100% exceeded
  BILL_REMINDER     // Bill due soon
  BILL_OVERDUE      // Bill past due
  SAVINGS_MILESTONE // Savings goal milestone reached
  SAVINGS_COMPLETED // Savings goal 100% completed
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}


// =============================================================================
// USER & AUTH
// =============================================================================

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?   // Profile picture URL
  password      String?   // Hashed password (for credentials login)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime? // Soft delete

  // Relations
  accounts      Account[]
  sessions      Session[]
  familyMembers FamilyMember[]
  transactions  Transaction[]
  notifications Notification[]
  settings      UserSettings?

  @@index([email])
  @@map("users")
}

// NextAuth.js tables
model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// =============================================================================
// FAMILY & MEMBERS
// =============================================================================

model Family {
  id        String    @id @default(uuid())
  name      String    // e.g., "Keluarga Padilla"
  currency  String    @default("IDR") // ISO 4217 currency code
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Soft delete

  // Relations
  members           FamilyMember[]
  transactions      Transaction[]
  categories        Category[]
  budgets           Budget[]
  savingsGoals      SavingsGoal[]
  bills             Bill[]
  recurringTemplates RecurringTransaction[]

  @@map("families")
}

model FamilyMember {
  id        String   @id @default(uuid())
  familyId  String
  userId    String
  role      Role     @default(CHILD)
  isActive  Boolean  @default(true) // Can be deactivated without deleting
  joinedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([familyId, userId]) // User can only be in a family once
  @@index([familyId])
  @@index([userId])
  @@map("family_members")
}

// =============================================================================
// CATEGORIES
// =============================================================================

model Category {
  id        String   @id @default(uuid())
  familyId  String
  name      String   // e.g., "Makanan", "Transport", "Gaji"
  type      TransactionType
  icon      String?  // Lucide icon name (optional)
  color     String?  // Hex color for UI (optional)
  isDefault Boolean  @default(false) // System default categories
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  family                Family                 @relation(fields: [familyId], references: [id], onDelete: Cascade)
  transactions          Transaction[]
  budgets               Budget[]
  recurringTransactions RecurringTransaction[]

  @@unique([familyId, name, type]) // Unique category names per family + type
  @@index([familyId, type])
  @@map("categories")
}

// =============================================================================
// TRANSACTIONS
// =============================================================================

model Transaction {
  id          String          @id @default(uuid())
  familyId    String
  userId      String          // Who created/recorded this transaction
  categoryId  String
  type        TransactionType
  amount      Decimal         @db.Decimal(19, 4) // Max 999,999,999,999,999.9999
  description String?
  date        DateTime        // Transaction date (can be past/future)
  attachments String[]        // Array of UploadThing file URLs
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?       // Soft delete

  // Relations
  family   Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([familyId, date(sort: Desc)]) // Most common query: list by family + date
  @@index([familyId, type])
  @@index([userId])
  @@index([categoryId])
  @@map("transactions")
}

// =============================================================================
// BUDGETS
// =============================================================================

model Budget {
  id         String       @id @default(uuid())
  familyId   String
  categoryId String
  amount     Decimal      @db.Decimal(19, 4) // Budget limit
  spent      Decimal      @default(0) @db.Decimal(19, 4) // Denormalized for performance
  period     BudgetPeriod @default(MONTHLY)
  startDate  DateTime     // Budget start date
  endDate    DateTime     // Budget end date
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  // Relations
  family   Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@unique([familyId, categoryId, startDate]) // One budget per category per period
  @@index([familyId, endDate])
  @@map("budgets")
}

// =============================================================================
// SAVINGS GOALS
// =============================================================================

model SavingsGoal {
  id          String    @id @default(uuid())
  familyId    String
  name        String    // e.g., "Liburan ke Bali"
  targetAmount Decimal   @db.Decimal(19, 4)
  currentAmount Decimal  @default(0) @db.Decimal(19, 4)
  deadline    DateTime?
  imageUrl    String?   // Goal image (uploaded via UploadThing)
  isCompleted Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyId, isCompleted])
  @@map("savings_goals")
}

// =============================================================================
// BILLS
// =============================================================================

model Bill {
  id             String    @id @default(uuid())
  familyId       String
  name           String    // e.g., "Listrik PLN"
  amount         Decimal   @db.Decimal(19, 4)
  dueDate        DateTime
  status         BillStatus @default(UPCOMING)
  isPaid         Boolean   @default(false)
  paidAt         DateTime?
  reminderDays   Int       @default(3) // Remind X days before due
  isRecurring    Boolean   @default(false)
  recurrenceRule String?   // JSON string for rrule (if recurring)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyId, dueDate])
  @@index([familyId, status])
  @@map("bills")
}

// =============================================================================
// RECURRING TRANSACTIONS
// =============================================================================

model RecurringTransaction {
  id          String              @id @default(uuid())
  familyId    String
  categoryId  String
  type        TransactionType
  amount      Decimal             @db.Decimal(19, 4)
  description String?
  frequency   RecurrenceFrequency
  startDate   DateTime
  endDate     DateTime?           // Null = indefinite
  isActive    Boolean             @default(true)
  lastRunAt   DateTime?           // Last time this generated a transaction
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  // Relations
  family   Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([familyId, isActive])
  @@map("recurring_transactions")
}

// =============================================================================
// NOTIFICATIONS
// =============================================================================

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  metadata  Json?            // Extra data (e.g., budgetId, billId, goalId)
  createdAt DateTime         @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}

// =============================================================================
// SETTINGS
// =============================================================================

model UserSettings {
  id        String   @id @default(uuid())
  userId    String   @unique
  theme     String   @default("system") // "light" | "dark" | "system"
  language  String   @default("id") // "id" | "en"
  currency  String   @default("IDR") // Default currency for new families
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}
