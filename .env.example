# ============================================
# Family Finance — Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.

# ---
# Database (Supabase PostgreSQL)
# ---
# Get this from: https://supabase.com/dashboard → Project Settings → Database
DATABASE_URL="postgresql://postgres:[password]@[host]:5432/postgres?pgbouncer=true&connection_limit=1"
# Direct URL (for Prisma migrations — bypasses pgBouncer)
DIRECT_URL="postgresql://postgres:[password]@[host]:5432/postgres"

# ---
# Auth.js
# ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-32-char-minimum-secret-here"

# Google OAuth
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ---
# UploadThing (File uploads)
# ---
# Get from: https://uploadthing.com/dashboard
UPLOADTHING_TOKEN="your-uploadthing-token"

# ---
# Resend (Transactional email)
# ---
# Get from: https://resend.com/api-keys
RESEND_API_KEY="re_your_resend_api_key"

# ---
# App URL
# ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---
# Optional: Skip env validation in CI
# ---
# SKIP_ENV_VALIDATION=true
